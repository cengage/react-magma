exports[`TreeView tree with hidden items renders tree with some items preselected, deselecting preselected items, clicking show all displays the rest of the tree and preselected items remain deselected 1`] = `
<DocumentFragment>
  .emotion-0 {
  list-style: none;
  margin: 0;
  padding: 0;
  background: transparent;
  border-bottom: 1px solid #D4D4D4;
  color: #707070;
  font-family: "Work Sans",Helvetica,sans-serif;
